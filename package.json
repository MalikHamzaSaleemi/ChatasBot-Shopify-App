{
  "name": "chatasbot",
  "private": true,
  "scripts": {
    "shopify-review": "shopify-app-store-review",
    "build": "remix vite:build",
    "dev": "npx shopify app dev --config shopify.app.toml",
    "config:link": "npx shopify app config link --config shopify.app.toml",
    "generate": "shopify app generate",
    "deploy": "npx shopify app deploy --config shopify.app.toml",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "remix-serve ./build/server/index.js",
    "setup": "prisma generate && prisma db push",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "npx shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite",
    "docker-start": "npm run setup && npm run build && npm run start"
  },
  "type": "module",
  "engines": {
    "node": "^18.20 || ^20.10 || >=21.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "@remix-run/dev": "^2.16.1",
    "@remix-run/fs-routes": "^2.16.1",
    "@remix-run/node": "^2.16.1",
    "@remix-run/react": "^2.16.1",
    "@remix-run/serve": "^2.16.1",
    "@shopify/app-bridge": "^3.7.10",
    "@shopify/app-bridge-react": "^4.1.6",
    "@shopify/polaris": "^12.0.0",
    "@shopify/shopify-app-remix": "^3.8.5",
    "@shopify/shopify-app-session-storage-prisma": "^6.0.0",
    "axios": "^1.10.0",
    "bullmq": "^5.56.4",
    "ioredis": "^5.6.1",
    "isbot": "^5.1.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite-tsconfig-paths": "^5.0.1"
  },
  "devDependencies": {
    "@remix-run/eslint-config": "^2.16.1",
    "@remix-run/route-config": "^2.16.1",
    "@shopify/api-codegen-preset": "^1.1.1",
    "@shopify/cli": "^3.93.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.2.0",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^18.2.31",
    "@types/react-dom": "^18.2.14",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.2.4",
    "prisma": "^6.10.1",
    "typescript": "^5.2.2",
    "vite": "^6.2.2"
